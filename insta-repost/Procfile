# Railway / Heroku Procfile
#
# ⚠️  --workers 1 is REQUIRED.
#     The APScheduler BackgroundScheduler lives inside the Gunicorn worker
#     process.  Multiple workers → duplicate scheduler instances → double-posting.
#     Scale vertically with --threads, not horizontally with --workers.
#
# Railway injects $PORT automatically (falls back to 8080 if unset).
web: gunicorn --bind 0.0.0.0:$PORT --workers 1 --threads 4 --timeout 120 --access-logfile - --error-logfile - main:app
