# ─────────────────────────────────────────────
# Flask / App
# ─────────────────────────────────────────────
# A long random secret key for Flask sessions
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Password that protects the web dashboard / submit form
APP_PASSWORD=supersecretpassword

# ─────────────────────────────────────────────
# Instagram / Meta Graph API
# ─────────────────────────────────────────────
# Your Instagram Business/Creator account numeric ID
IG_USER_ID=123456789

# Long-lived User Access Token (60 days) from Graph API Explorer
IG_ACCESS_TOKEN=EAA...

# Facebook App credentials (from developers.facebook.com)
FB_APP_ID=987654321
FB_APP_SECRET=abc123def456

# ─────────────────────────────────────────────
# Google Sheets Queue
# ─────────────────────────────────────────────
# Full JSON contents of the service account key file (single line, escaped)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Exact name of the Google Sheet used as the queue
GOOGLE_SHEET_NAME=MemeQueue

# ─────────────────────────────────────────────
# Downloader Burner Account
# ─────────────────────────────────────────────
# Throwaway Instagram account used by instaloader (NOT your main account)
IG_LOGIN_USER=burner_account_username
IG_LOGIN_PASS=burner_account_password

# ─────────────────────────────────────────────
# Scheduler / Rate Limiting
# ─────────────────────────────────────────────
# Minutes between automatic post attempts
POST_INTERVAL_MINUTES=60

# Maximum number of posts allowed per calendar day
MAX_POSTS_PER_DAY=5

# Posting window — posts will only be published within these hours (24h format)
POSTING_HOURS_START=8
POSTING_HOURS_END=22

# ─────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Port the Flask server listens on
PORT=8080
